<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AstroGuru AI</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<div class="container">

  <h1>🔮 AstroGuru AI</h1>
  <p class="subtitle">Ancient Vedic Wisdom Powered By AI</p>

  <input type="text" id="name" placeholder="Enter Your Name">

  <input type="text" id="birthTime" placeholder="Birth Time (08:39)">

  <input type="text" id="birthPlace" placeholder="Birth Place">

  <select id="day">
    <option value="">Date</option>
  </select>

  <select id="month">
    <option value="">Month</option>
    <option value="January">January</option>
    <option value="February">February</option>
    <option value="March">March</option>
    <option value="April">April</option>
    <option value="May">May</option>
    <option value="June">June</option>
    <option value="July">July</option>
    <option value="August">August</option>
    <option value="September">September</option>
    <option value="October">October</option>
    <option value="November">November</option>
    <option value="December">December</option>
  </select>

  <select id="year">
    <option value="">Year</option>
  </select>

  <button onclick="generatePrediction()">
    Generate Prediction
  </button>

  <div id="result"></div>

</div>

<script src="script.js"></script>

</body>
</html>